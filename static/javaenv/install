#!/usr/bin/env bash
set -euo pipefail

JAVAENV_DIR="${HOME}/.local/share/javaenv"
JAVAENV_BIN="${JAVAENV_DIR}/bin"
BIN_DIR="${HOME}/.local/bin"
GITHUB_RAW_URL="https://raw.githubusercontent.com/latte-java/javaenv/main/javaenv"

echo "Installing javaenv..."

# Create directories
mkdir -p "${JAVAENV_BIN}"
mkdir -p "${BIN_DIR}"
mkdir -p "${HOME}/.local/share/java"

# If running from a local clone, copy the script; otherwise download from GitHub
SOURCE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-}" 2>/dev/null)" 2>/dev/null && pwd 2>/dev/null || echo "")"

if [[ -n "${SOURCE_DIR}" && -f "${SOURCE_DIR}/javaenv" ]]; then
  echo "Installing from local source..."
  cp "${SOURCE_DIR}/javaenv" "${JAVAENV_BIN}/javaenv"
else
  echo "Downloading javaenv from GitHub..."
  if ! curl -fsSL -o "${JAVAENV_BIN}/javaenv" "${GITHUB_RAW_URL}"; then
    echo "Error: Failed to download javaenv from ${GITHUB_RAW_URL}" >&2
    exit 1
  fi
fi

chmod +x "${JAVAENV_BIN}/javaenv"

# Symlink to ~/.local/bin
ln -sf "${JAVAENV_BIN}/javaenv" "${BIN_DIR}/javaenv"

# Verify ~/.local/bin is in PATH
if ! echo "${PATH}" | tr ':' '\n' | grep -qx "${BIN_DIR}"; then
  echo ""
  echo "WARNING: ${BIN_DIR} is not in your PATH."
  echo "Add the following to your shell profile:"
  echo ""
  echo "  export PATH=\"\${HOME}/.local/bin:\${PATH}\""
  echo ""
fi

echo "Installed javaenv to ${JAVAENV_BIN}/javaenv"
echo "Symlinked to ${BIN_DIR}/javaenv"
echo ""
echo "Run 'javaenv install <version>' to install a JDK (e.g., javaenv install 17.0.18+8)"
